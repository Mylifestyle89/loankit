// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── Better Auth Models ───────────────────────────────────

model User {
  id            String    @id
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          String    @default("viewer") // admin | editor | viewer
  banned        Boolean?
  banReason     String?
  banExpires    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  twoFactorEnabled Boolean?  @default(false)

  sessions   Session[]
  accounts   Account[]
  twoFactor  TwoFactor?

  @@map("user")
}

model TwoFactor {
  id          String @id @default(cuid())
  secret      String
  backupCodes String // JSON array of hashed backup codes
  userId      String @unique
  user        User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("twoFactor")
}

model Session {
  id        String   @id
  token     String   @unique
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([token])
  @@map("session")
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("verification")
}

// ─── Application Models ───────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer_code  String   @unique
  customer_name  String
  customer_type  String   @default("corporate") // "corporate" | "individual"
  address        String?
  main_business  String?
  charter_capital Float?
  legal_representative_name  String?
  legal_representative_title String?
  organization_type          String?

  // Individual-specific fields (nullable, ignored for corporate)
  cccd               String?   // CCCD/CMND number
  cccd_old           String?   // CMND cũ (9 số)
  cccd_issued_date   String?   // Ngày cấp CCCD (e.g. "13/04/2021")
  cccd_issued_place  String?   // Nơi cấp CCCD
  date_of_birth      String?   // Năm sinh (e.g. "1969")
  gender             String?   // "male" | "female"
  phone              String?   // Số điện thoại
  marital_status     String?   // "single" | "married" | "divorced" | "widowed"
  spouse_name        String?   // Họ tên vợ/chồng
  spouse_cccd        String?   // CCCD vợ/chồng
  bank_account       String?   // Số tài khoản ngân hàng
  bank_name          String?   // Nơi mở tài khoản
  cic_product_name   String?   // Tên sản phẩm TTTD (tra cứu CIC)
  cic_product_code   String?   // Mã sản phẩm TTTD

  email    String?   // Email nhan thong bao hoa don

  // Branch & staff assignment
  active_branch_id      String?  // FK to Branch (selected active branch)
  active_branch         Branch?  @relation(fields: [active_branch_id], references: [id], onDelete: SetNull)
  relationship_officer  String?  // Cán bộ quan hệ khách hàng
  appraiser             String?  // Người thẩm định
  approver_name         String?  // Người phê duyệt
  approver_title        String?  // Chức vụ: "Giám đốc" | "Phó Giám đốc"

  /// JSON object: extra attributes (report field_key -> value) for mapping/export
  data_json String? @default("{}")

  mapping_instances MappingInstance[]
  loans            Loan[]
  loan_plans       LoanPlan[]
  collaterals      Collateral[]
  co_borrowers     CoBorrower[]
  related_persons  RelatedPerson[]
  credit_agribank  CreditAtAgribank[]
  credit_other     CreditAtOther[]

  @@index([customer_type])
  @@index([active_branch_id])
  @@map("customers")
}

model Loan {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contractNumber  String   @unique
  loanAmount      Float
  interestRate    Float?
  startDate       DateTime
  endDate         DateTime
  purpose              String?
  loan_method          String   @default("tung_lan") // tung_lan | han_muc | trung_dai | tieu_dung
  disbursementCount    String?
  collateralValue      Float?
  securedObligation    Float?
  disbursementLimitByAsset Float?
  status               String   @default("active") // active | completed | cancelled

  // Điều kiện cho vay
  lending_method       String?  // Phương thức cho vay
  tcmblm_reason        String?  // Lý do đáp ứng/không đáp ứng TCMBLM
  interest_method      String?  // Phương thức áp dụng LS
  principal_schedule   String?  // Định kỳ trả gốc
  interest_schedule    String?  // Định kỳ trả lãi
  policy_program       String?  // Chương trình cho vay theo chính sách

  // Nguồn vốn & Vốn đối ứng
  total_capital_need   Float?   // Tổng nhu cầu vốn
  equity_amount        Float?   // Vốn đối ứng
  cash_equity          Float?   // Vốn bằng tiền
  labor_equity         Float?   // Vốn bằng sức lao động
  other_loan           Float?   // Vốn vay TCTD khác
  other_asset_equity   Float?   // Vốn bằng tài sản khác

  // Hiệu quả & Xếp hạng
  expected_revenue     Float?   // Tổng doanh thu dự kiến
  expected_cost        Float?   // Tổng chi phí dự kiến
  expected_profit      Float?   // Lợi nhuận dự kiến
  from_project         String?  // Từ phương án, dự án
  other_income         String?  // Thu nhập khác
  other_income_detail  String?  // Cụ thể về thu nhập khác
  customer_rating      String?  // Xếp hạng khách hàng
  debt_group           String?  // Nhóm nợ
  scoring_period       String?  // Kỳ chấm điểm

  // HĐ cũ (cho vay tái cơ cấu, gia hạn)
  prior_contract_number String?  // Số HĐ cũ
  prior_contract_date   String?  // Ngày HĐ cũ
  prior_outstanding     Float?   // Dư nợ cũ

  disbursements     Disbursement[]
  beneficiaries     Beneficiary[]

  @@index([customerId])
  @@index([status])
  @@index([loan_method])
  @@map("loans")
}

model Beneficiary {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  loanId        String
  loan          Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  name          String   // Don vi thu huong
  address       String?  // Dia chi
  accountNumber String?  // So tai khoan
  bankName      String?  // Ngan hang thu huong

  disbursementLines DisbursementBeneficiary[]

  @@index([loanId])
  @@map("beneficiaries")
}

model Disbursement {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  loanId           String
  loan             Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amount           Float
  disbursementDate DateTime
  description      String?
  status           String   @default("active") // active | completed | cancelled

  // Expanded fields (Phase P2)
  currentOutstanding   Float?    // Du no hien tai (snapshot)
  debtAmount           Float?    // So tien nhan no
  totalOutstanding     Float?    // Tong du no (snapshot)
  purpose              String?   // Muc dich
  supportingDoc        String?   // Tai lieu chung minh
  loanTerm             Int?      // Thoi han cho vay (months)
  repaymentEndDate     DateTime? // Han tra cuoi cung
  principalSchedule    String?   // Dinh ky tra goc
  interestSchedule     String?   // Dinh ky tra lai

  invoices             Invoice[]
  beneficiaryLines     DisbursementBeneficiary[]

  @@index([loanId])
  @@index([status])
  @@index([loanId, disbursementDate])
  @@map("disbursements")
}

model DisbursementBeneficiary {
  id              String       @id @default(cuid())
  createdAt       DateTime     @default(now())
  disbursementId  String
  disbursement    Disbursement @relation(fields: [disbursementId], references: [id], onDelete: Cascade)
  beneficiaryId   String?
  beneficiary     Beneficiary? @relation(fields: [beneficiaryId], references: [id], onDelete: SetNull)
  beneficiaryName String       // snapshot: KH thu huong
  address         String?      // snapshot: Dia chi
  accountNumber   String?      // snapshot: So TK
  bankName        String?      // snapshot: Ngan hang
  amount          Float        // So tien giai ngan cho don vi nay
  invoiceStatus   String       @default("pending") // pending | supplementing | has_invoice
  invoiceAmount   Float        @default(0)

  invoices        Invoice[]

  @@index([disbursementId])
  @@index([beneficiaryId])
  @@map("disbursement_beneficiaries")
}

model Invoice {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  disbursementId String
  disbursement   Disbursement @relation(fields: [disbursementId], references: [id], onDelete: Cascade)
  disbursementBeneficiaryId String?
  disbursementBeneficiary   DisbursementBeneficiary? @relation(fields: [disbursementBeneficiaryId], references: [id], onDelete: SetNull)
  invoiceNumber  String
  supplierName   String
  amount         Float
  issueDate      DateTime
  dueDate        DateTime
  customDeadline DateTime?
  status         String       @default("pending") // pending | paid | overdue
  notes          String?
  qty            Float?       // Bảng kê: số lượng
  unitPrice      Float?       // Bảng kê: đơn giá

  @@index([invoiceNumber, supplierName])
  @@index([disbursementId])
  @@index([disbursementBeneficiaryId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model AppNotification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  readAt    DateTime?
  type      String    // invoice_due_soon | invoice_overdue | duplicate_invoice
  title     String
  message   String
  metadata  String?   @default("{}") // JSON: { invoiceId, disbursementId, customerId }
  emailSentAt      DateTime?  // Thoi diem gui email
  emailError       String?    // Loi gui email (neu co)

  @@index([readAt])
  @@index([type])
  @@index([type, createdAt])
  @@map("app_notifications")
}

model FieldTemplateMaster {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  name             String
  description      String?
  status           String   @default("active")
  fieldCatalogJson String   @default("[]")
  createdBy        String   @default("system")

  mapping_instances MappingInstance[]

  @@index([status])
  @@map("field_template_masters")
}

model MappingInstance {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  name           String
  status         String   @default("draft")
  createdBy      String   @default("web-user")
  publishedAt    DateTime?
  mappingJsonPath String
  aliasJsonPath   String
  masterSnapshotName String @default("")
  fieldCatalogJson   String @default("[]")

  /// JSON content stored directly — avoids filesystem writes on Vercel (EROFS)
  mappingJson    String?
  aliasJson      String?

  masterId   String?
  customerId String
  master     FieldTemplateMaster? @relation(fields: [masterId], references: [id], onDelete: SetNull)
  customer   Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([masterId])
  @@index([customerId])
  @@index([customerId, masterId, status])
  @@map("mapping_instances")
}

// ─── Report Config (replaces filesystem framework_state.json) ────
model ReportConfig {
  key       String   @id
  valueJson String   @default("{}")
  updatedAt DateTime @updatedAt

  @@map("report_configs")
}

// ─── Loan Plan (Phương án vay vốn) ─────────────────────────

model LoanPlanTemplate {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String   // e.g. "Trồng hoa Cát tường", "Kinh doanh tạp hóa"
  category    String   // nong_nghiep | kinh_doanh | chan_nuoi | an_uong | xay_dung | han_muc
  description String?

  /// JSON: default cost items [{ name, unit, default_price }]
  cost_items_template_json String @default("[]")
  /// JSON: revenue template [{ description, formula }]
  revenue_template_json    String @default("[]")
  /// JSON: default values { interest_rate, tax_rate, ... }
  defaults_json            String @default("{}")

  loan_plans LoanPlan[]

  @@index([category])
  @@map("loan_plan_templates")
}

model LoanPlan {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  customerId  String
  customer    Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  templateId  String?
  template    LoanPlanTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  name        String  @default("")  // e.g. "PA trồng 6 sào hoa Cát tường"
  loan_method String  @default("tung_lan") // tung_lan | han_muc | trung_dai | tieu_dung
  status      String  @default("draft")    // draft | approved

  /// JSON: cost line items [{ name, unit, qty, unit_price, amount }]
  cost_items_json    String @default("[]")
  /// JSON: revenue line items [{ description, qty, unit_price, amount }]
  revenue_items_json String @default("[]")
  /// JSON: computed financials { totalCost, revenue, profit, loanAmount, counterpartCapital, ... }
  financials_json    String @default("{}")

  @@index([customerId])
  @@index([status])
  @@map("loan_plans")
}

/// Tài sản bảo đảm — JSON properties for type-specific fields
model Collateral {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  collateral_type String   // "qsd_dat" | "tiet_kiem" | "dong_san" | "tai_san_khac"
  name            String   @default("") // Tên TSBĐ
  total_value     Float?   // Tổng giá trị TS
  obligation      Float?   // Nghĩa vụ bảo đảm

  /// JSON: type-specific properties (e.g. land: { address, area, lot_number, ... })
  properties_json String   @default("{}")

  @@index([customerId])
  @@index([collateral_type])
  @@map("collaterals")
}

/// Người đồng vay vốn
model CoBorrower {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  title           String?  // Danh xưng (Ông/Bà)
  full_name       String   // Họ và tên
  id_type         String?  // Loại giấy tờ tùy thân
  id_number       String?  // CMND/CCCD
  id_issued_date  String?  // Ngày cấp
  id_old          String?  // CMND cũ
  id_issued_place String?  // Nơi cấp
  birth_year      String?  // Năm sinh
  phone           String?  // Số điện thoại
  current_address String?  // Địa chỉ hiện tại
  permanent_address String? // Nơi thường trú
  relationship    String?  // Mối quan hệ với KH vay
  agribank_debt   String?  // Dư nợ tại Agribank
  agribank_branch String?  // Tên chi nhánh Agribank

  @@index([customerId])
  @@map("co_borrowers")
}

/// Người có liên quan
model RelatedPerson {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  name            String   // Tên tổ chức/Cá nhân
  id_number       String?  // Số ĐKKD/CMND
  address         String?  // Địa chỉ
  relation_type   String?  // Mối liên quan
  agribank_debt   String?  // Dư nợ tại Agribank
  agribank_branch String?  // Tên chi nhánh Agribank

  @@index([customerId])
  @@map("related_persons")
}

/// Thông tin tín dụng tại Agribank
model CreditAtAgribank {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  branch_name      String?  // Tại chi nhánh/PGD
  debt_group       String?  // Nhóm nợ
  loan_term        String?  // Thời hạn vay
  debt_amount      String?  // Dư nợ
  loan_purpose     String?  // Mục đích vay
  repayment_source String?  // Nguồn trả nợ

  @@index([customerId])
  @@map("credit_at_agribank")
}

/// Thông tin tín dụng tại TCTD khác
model CreditAtOther {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  institution_name String? // Tên TCTD
  debt_group       String? // Nhóm nợ
  loan_term        String? // Thời hạn vay
  debt_amount      String? // Dư nợ
  loan_purpose     String? // Mục đích vay
  repayment_source String? // Nguồn trả nợ

  @@index([customerId])
  @@map("credit_at_other")
}

/// Generic dropdown options - user-managed per field_key
model DropdownOption {
  id         String @id @default(cuid())
  field_key  String // e.g. "approver_title", "debt_group"
  label      String // display text
  sort_order Int    @default(0)

  @@unique([field_key, label])
  @@index([field_key])
  @@map("dropdown_options")
}

/// Chi nhánh / Phòng giao dịch
model Branch {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  name            String   // Tên chi nhánh/PGD
  name_uppercase  String?  // Tên gọi in hoa
  address         String?  // Địa chỉ trụ sở
  branch_code     String?  // Mã CN
  phone           String?  // Điện thoại
  fax             String?  // Fax
  tax_code        String?  // Mã số thuế CN
  tax_issued_date String?  // Ngày cấp MST
  tax_issued_place String? // Nơi cấp MST
  district        String?  // Quận/Huyện
  province        String?  // Tỉnh/TP

  customers       Customer[]

  @@map("branches")
}
