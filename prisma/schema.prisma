// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Customer {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer_code  String   @unique
  customer_name  String
  address        String?
  main_business  String?
  charter_capital Float?
  legal_representative_name  String?
  legal_representative_title String?
  organization_type          String?

  /// JSON object: extra attributes (report field_key -> value) for mapping/export
  data_json String? @default("{}")

  mapping_instances MappingInstance[]
  loans            Loan[]

  @@map("customers")
}

model Loan {
  id              String   @id @default(cuid())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  customerId      String
  customer        Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  contractNumber  String   @unique
  loanAmount      Float
  interestRate    Float?
  startDate       DateTime
  endDate         DateTime
  purpose              String?
  disbursementCount    String?
  collateralValue      Float?
  securedObligation    Float?
  status               String   @default("active") // active | completed | cancelled
  disbursements     Disbursement[]

  @@index([customerId])
  @@index([status])
  @@map("loans")
}

model Disbursement {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  loanId           String
  loan             Loan     @relation(fields: [loanId], references: [id], onDelete: Cascade)
  amount           Float
  disbursementDate DateTime
  description      String?
  status           String   @default("active") // active | completed | cancelled
  invoices         Invoice[]

  @@index([loanId])
  @@index([status])
  @@index([loanId, disbursementDate])
  @@map("disbursements")
}

model Invoice {
  id             String       @id @default(cuid())
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  disbursementId String
  disbursement   Disbursement @relation(fields: [disbursementId], references: [id], onDelete: Cascade)
  invoiceNumber  String
  supplierName   String
  amount         Float
  issueDate      DateTime
  dueDate        DateTime
  customDeadline DateTime?
  status         String       @default("pending") // pending | paid | overdue
  notes          String?

  @@unique([invoiceNumber, supplierName])
  @@index([disbursementId])
  @@index([status])
  @@index([dueDate])
  @@map("invoices")
}

model AppNotification {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  readAt    DateTime?
  type      String    // invoice_due_soon | invoice_overdue | duplicate_invoice
  title     String
  message   String
  metadata  String?   @default("{}") // JSON: { invoiceId, disbursementId, customerId }

  @@index([readAt])
  @@index([type])
  @@map("app_notifications")
}

model FieldTemplateMaster {
  id               String   @id @default(cuid())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  name             String
  description      String?
  status           String   @default("active")
  fieldCatalogJson String   @default("[]")

  mapping_instances MappingInstance[]

  @@index([status])
  @@map("field_template_masters")
}

model MappingInstance {
  id             String   @id @default(cuid())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  name           String
  status         String   @default("draft")
  createdBy      String   @default("web-user")
  publishedAt    DateTime?
  mappingJsonPath String
  aliasJsonPath   String
  masterSnapshotName String @default("")
  fieldCatalogJson   String @default("[]")

  masterId   String?
  customerId String
  master     FieldTemplateMaster? @relation(fields: [masterId], references: [id], onDelete: SetNull)
  customer   Customer            @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@index([masterId])
  @@index([customerId])
  @@index([customerId, masterId, status])
  @@map("mapping_instances")
}
