# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/src/generated/prisma

# python
__pycache__/
*.pyc

# local databases
*.db

# local data sources (do not commit)
*.xlsx
*.xlsm
*.bk

# report runtime outputs (generated)
/report_assets/config/
/report_assets/report_draft*.json
/report_assets/validation_report.json
/report_assets/template_export_report*.json
/report_assets/*export_report*.json
/report_assets/*injection_report*.json
/report_assets/strip_prefix_report.json
/report_assets/report_preview*.docx
/report_assets/*preview*.docx
/report_assets/*trial*.docx
