{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm audit fix)",
      "Bash(npm run build)",
      "Bash(find . -name \"*.ts\" -type f ! -path \"./node_modules/*\" ! -path \"./.next/*\" -exec grep -l \"listMasterTemplates\" {} ;)",
      "Bash(npx prisma generate)",
      "Bash(npm run lint -- src)",
      "Bash(npx prisma migrate deploy)",
      "Bash(npx prisma db push --skip-generate)",
      "Bash(npx prisma db push --accept-data-loss)",
      "Bash(sqlite3 dev.db \".tables\")",
      "Bash(python3:*)",
      "Bash(npx tsc --noEmit)",
      "Bash(npm install jsonwebtoken)",
      "Bash(npm install -D @types/jsonwebtoken)",
      "Bash(docker run -d --name onlyoffice -p 8080:80 onlyoffice/documentserver)",
      "Bash(docker exec onlyoffice bash -c 'cat /etc/onlyoffice/documentserver/local.json 2>/dev/null | python3 -m json.tool 2>/dev/null || cat /etc/onlyoffice/documentserver/local.json 2>/dev/null || echo \"\"File not found\"\"')"
    ]
  }
}
